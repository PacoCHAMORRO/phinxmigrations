{
  "name": "phinx-migration-helper",
  "displayName": "Phinx Migration Helper",
  "description": "Execute Phinx migration commands directly from VSCode, with optional Docker support.",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": ["Other"],
  "activationEvents": ["workspaceContains:composer.json"],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "phinx.createMigration",
        "title": "Phinx: Create Migration"
      },
      {
        "command": "phinx.migrate",
        "title": "Phinx: Migrate"
      },
      {
        "command": "phinx.rollback",
        "title": "Phinx: Rollback"
      }
    ],
    "configuration": {
      "title": "Phinx Migration Helper",
      "properties": {
        "phinx.useDocker": {
          "type": "boolean",
          "default": false,
          "description": "Execute commands inside a Docker container"
        },
        "phinx.dockerMethod": {
          "type": "string",
          "enum": ["docker-compose", "docker"],
          "default": "docker-compose",
          "description": "Method to execute in Docker: 'docker-compose' or 'docker exec'"
        },
        "phinx.dockerContainer": {
          "type": "string",
          "default": "php-fpm",
          "description": "Name of the Docker container (e.g., php-fpm, app, web)"
        },
        "phinx.dockerComposeService": {
          "type": "string",
          "default": "php-fpm",
          "description": "Name of the service in docker-compose.yml"
        },
        "phinx.phinxPath": {
          "type": "string",
          "default": "composer_modules/bin/phinx",
          "description": "Path to phinx (relative to the project root)"
        },
        "phinx.workingDirectory": {
          "type": "string",
          "default": "./",
          "description": "Working directory inside the container"
        },
        "phinx.migrationsDirectory": {
          "type": "string",
          "default": "db/migrations",
          "description": "Path to the migrations directory"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.60.0",
    "@types/node": "^14.0.0",
    "@types/mocha": "^9.0.0",
    "typescript": "^4.0.0"
  }
}