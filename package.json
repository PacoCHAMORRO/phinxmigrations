{
  "name": "phinx-migration-helper",
  "displayName": "Phinx Migration Helper",
  "description": "Ejecuta comandos de Phinx (create, migrate, rollback) desde VSCode, con soporte para Docker",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": ["Other"],
  "activationEvents": ["workspaceContains:composer.json"],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "phinx.createMigration",
        "title": "Phinx: Create Migration"
      },
      {
        "command": "phinx.migrate",
        "title": "Phinx: Migrate"
      },
      {
        "command": "phinx.rollback",
        "title": "Phinx: Rollback"
      }
    ],
    "configuration": {
      "title": "Phinx Migration Helper",
      "properties": {
        "phinx.useDocker": {
          "type": "boolean",
          "default": false,
          "description": "Ejecutar comandos dentro de un contenedor Docker"
        },
        "phinx.dockerMethod": {
          "type": "string",
          "enum": ["docker-compose", "docker"],
          "default": "docker-compose",
          "description": "Método para ejecutar en Docker: 'docker-compose' o 'docker exec'"
        },
        "phinx.dockerContainer": {
          "type": "string",
          "default": "php-fpm",
          "description": "Nombre del contenedor Docker (ej: php-fpm, app, web)"
        },
        "phinx.dockerComposeService": {
          "type": "string",
          "default": "php-fpm",
          "description": "Nombre del servicio en docker-compose.yml"
        },
        "phinx.phinxPath": {
          "type": "string",
          "default": "composer_modules/bin/phinx",
          "description": "Ruta a phinx (relativa a la raíz del proyecto)"
        },
        "phinx.workingDirectory": {
          "type": "string",
          "default": "./",
          "description": "Directorio de trabajo dentro del contenedor"
        },
        "phinx.migrationsDirectory": {
          "type": "string",
          "default": "db/migrations",
          "description": "Ruta al directorio de migraciones"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.60.0",
    "@types/node": "^14.0.0",
    "@types/mocha": "^9.0.0",
    "typescript": "^4.0.0"
  }
}